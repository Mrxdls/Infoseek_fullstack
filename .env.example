# ─── App ───────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=changeme_super_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ──────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ragapp
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@postgres:5432/ragapp

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── S3 / Object Storage ───────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=rag-documents

# ─── Vector DB (Qdrant) ────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=rag_chunks

# ─── LLM APIs ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
SMALL_MODEL=gpt-3.5-turbo
LARGE_MODEL=gpt-4o

# ─── Google Vision (OCR) ───────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google_vision.json

# ─── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_AUTH=60        # requests per minute
RATE_LIMIT_ANON=10        # requests per minute

# ─── Frontend ──────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
